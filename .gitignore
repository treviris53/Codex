# -------------------------------------------------------------------
# Home Assistant local runtime / machine-local artifacts
# Keep deployable YAML and scripts in repo, ignore only local state.
# -------------------------------------------------------------------

# Local HA runtime snapshot (read-only reference only)
_ha_runtime_snapshot/
ha_runtime_snapshot/

# Home Assistant internal runtime/state
.storage/
.ha_run.lock
.HA_VERSION
ip_bans.yaml
home-assistant.log
home-assistant.log.*
*.fault

# Local backups / temporary exports
backup/
backups/
backup_deploy/
*.bak
*.tar
*.msix

# Databases
home-assistant_v2.db
home-assistant_v2.db-shm
home-assistant_v2.db-wal

# Cache / Python
__pycache__/
*.pyc

# Editor / OS
.DS_Store
Thumbs.db
.vscode/

# Optional local integration/runtime dirs that should not be versioned
deps/
tts/
zigbee2mqtt/
esphome/.esphome/

# Secrets / private material
secrets.yaml
*.pem
*.key