#!/usr/bin/env bash
# Version: 1.2.2
# pre-commit policy:
# - Block commits of local-only/sensitive paths (even if force-added)
# - Normalize CRLF->LF for staged .sh/.yaml/.yml + remove BOM
# - Trim trailing blank lines at EOF (prevents yamllint empty-lines max-end:0)
# - Ensure newline at EOF
# - Block staged files that are ignored by .gitignore (detects git add -f accidents)

set -euo pipefail
cd "$(git rev-parse --show-toplevel)" >/dev/null

fail() { echo "ERROR: $*" >&2; exit 1; }

FORBIDDEN_ERE='^(custom_components/|templates/|www/|esphome/|homematicip_local/|zigbee2mqtt/|local/|tts/|\.cloud/|\.storage/|secrets\.yaml$|ip_bans\.yaml$|known_devices\.yaml$|home-assistant\.log|home-assistant_v2\.db|home-assistant\.log\.fault$|\.ha_run\.lock$|\.github_pat$)'

mapfile -t files < <(git diff --cached --name-only --diff-filter=ACMR)
[[ "${#files[@]}" -eq 0 ]] && exit 0

bad=()
ignored=()
for f in "${files[@]}"; do
  if echo "$f" | grep -Eq "$FORBIDDEN_ERE"; then
    bad+=("$f")
    continue
  fi
  if git check-ignore -q -- "$f"; then
    ignored+=("$f")
  fi
done

if [[ "${#bad[@]}" -gt 0 ]]; then
  echo "Local-only/sensitive paths are staged and must NOT be committed:" >&2
  printf '  - %s\n' "${bad[@]}" >&2
  fail "Unstage these paths before committing."
fi

if [[ "${#ignored[@]}" -gt 0 ]]; then
  echo "Ignored files are staged (likely 'git add -f'). This is blocked:" >&2
  printf '  - %s\n' "${ignored[@]}" >&2
  fail "Remove them from the index: git reset -- <path>"
fi

for f in "${files[@]}"; do
  case "$f" in
    *.sh|*.yaml|*.yml) ;;
    *) continue ;;
  esac
  [[ -f "$f" ]] || continue

  changed=0

  # Remove UTF-8 BOM
  if head -c 3 "$f" 2>/dev/null | grep -q $'\xEF\xBB\xBF'; then
    tmp="$(mktemp)"
    tail -c +4 "$f" > "$tmp" || true
    mv "$tmp" "$f"
    changed=1
  fi

  # CRLF -> LF
  if grep -q $'\r' "$f" 2>/dev/null; then
    tmp="$(mktemp)"
    tr -d '\r' < "$f" > "$tmp"
    mv "$tmp" "$f"
    changed=1
  fi

  # Trim trailing blank lines at EOF (whitespace-only lines)
  tmp="$(mktemp)"
  awk '{a[NR]=$0} $0 ~ /[^[:space:]]/ {last=NR} END{for(i=1;i<=last;i++) print a[i]}' "$f" > "$tmp"
  mv "$tmp" "$f"
  changed=1

  # Ensure newline at EOF
  if [[ -s "$f" ]]; then
    lastc="$(tail -c 1 "$f" || true)"
    if [[ "$lastc" != $'\n' ]]; then
      echo "" >> "$f"
      changed=1
    fi
  fi

  if [[ "$changed" -eq 1 ]]; then
    git add -- "$f"
    echo "pre-commit: normalized text file: $f" >&2
  fi
done

exit 0
