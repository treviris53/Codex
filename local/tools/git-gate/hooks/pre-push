#!/usr/bin/env bash
# Version: 1.4.1
set -euo pipefail

REMOTE_NAME="${1:-}"
REMOTE_URL="${2:-}"
cd "$(git rev-parse --show-toplevel)" >/dev/null

fail() { echo "ERROR: $*" >&2; exit 1; }
is_zero_sha() { [[ "${1:-}" =~ ^0{40}$ ]]; }

# IMPORTANT: single-line regex, no newlines, no trailing "|"
FORBIDDEN_ERE='^(custom_components/|templates/|www/|esphome/|homematicip_local/|zigbee2mqtt/|local/|tts/|\.cloud/|\.storage/|secrets\.yaml$|ip_bans\.yaml$|known_devices\.yaml$|home-assistant\.log|home-assistant_v2\.db|home-assistant\.log\.fault$|\.ha_run\.lock$|\.github_pat$)'

REQUIRED_GITIGNORE_PATTERNS=(
  '^/?secrets\.yaml$'
  '^/?ip_bans\.yaml$'
  '^/?known_devices\.yaml$'
  '^/?\.cloud/$'
  '^/?\.storage/$'
  '^/?custom_components/$'
  '^/?templates/$'
  '^/?www/$'
  '^/?esphome/$'
  '^/?homematicip_local/$'
  '^/?zigbee2mqtt/$'
  '^/?local/$'
  '^/?tts/$'
  '^/?home-assistant_v2\.db\*'
  '^/?home-assistant\.log\*'
  '^/?home-assistant\.log\.fault$'
  '^/?\.ha_run\.lock$'
)

current_branch="$(git rev-parse --abbrev-ref HEAD 2>/dev/null || echo '')"

if [[ "$current_branch" == "main" ]]; then
  fail "Direct pushes from 'main' are blocked. Switch to 'staging' and merge via PR."
fi
if [[ "$current_branch" != "staging" ]]; then
  fail "Push is only allowed from 'staging'. Current: '$current_branch'"
fi

[[ -f .gitignore ]] || fail ".gitignore not found at repo root."
missing=0
for pat in "${REQUIRED_GITIGNORE_PATTERNS[@]}"; do
  if ! grep -Eq "$pat" .gitignore; then
    echo "Missing required .gitignore rule (regex): $pat" >&2
    missing=1
  fi
done
[[ "$missing" -eq 0 ]] || fail ".gitignore missing required ignore rules. Refusing push."

if git ls-files | grep -Eq "$FORBIDDEN_ERE"; then
  echo "Forbidden paths are TRACKED in Git (must not happen):" >&2
  git ls-files | grep -E "$FORBIDDEN_ERE" | head -n 300 >&2
  fail "Refusing push. Remove from index with: git rm -r --cached --ignore-unmatch <paths>"
fi

while read -r local_ref local_sha remote_ref remote_sha; do
  [[ -z "${local_ref:-}" ]] && continue

  if [[ "$remote_ref" == "refs/heads/main" ]]; then
    fail "Direct pushes to 'main' are blocked. Push to 'staging' and merge via PR."
  fi
  if [[ "$local_ref" == "refs/heads/main" ]]; then
    fail "Pushing from local 'main' is blocked. Switch to 'staging'."
  fi
  if is_zero_sha "${local_sha:-}"; then
    continue
  fi

  if is_zero_sha "${remote_sha:-}"; then
    changes="$(git diff-tree --no-commit-id --name-status -r "$local_sha" || true)"
  else
    changes="$(git diff --name-status --no-renames "$remote_sha" "$local_sha" || true)"
  fi

  while IFS= read -r line; do
    [[ -z "$line" ]] && continue
    status="$(awk '{print $1}' <<<"$line")"
    path="$(awk '{print $NF}' <<<"$line")"
    [[ "$status" == D* ]] && continue
    if echo "$path" | grep -Eq "$FORBIDDEN_ERE"; then
      echo "Forbidden path would be pushed ($status): $path" >&2
      fail "Refusing push. These paths must remain local-only."
    fi
  done <<<"$changes"
done

exit 0
