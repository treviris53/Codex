        </mxCell>
        <mxCell id="note3" parent="1" value="Naechste Schritte&#xa;• smallnet-5g spaeter entfernen&#xa;• spaetere UniFi-Managed-Switch-Umruestung fuer mehr kabelgebundene VLAN-Fuehrung&#xa;• Zielbild FTTH: ONT -&gt; UCGF direkt" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;" vertex="1">
