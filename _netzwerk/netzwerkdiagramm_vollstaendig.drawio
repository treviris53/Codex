        </mxCell>
        <mxCell id="note2" parent="1" value="WiFi-Hinweis&#xa;• Smallnet: MLO bewusst deaktiviert&#xa;• smallnet-iot ohne Fast Roaming / BSS-Experimente&#xa;• 2.4 GHz fuer IoT ist im aktuellen Umfeld bewusst ausreichend" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;" vertex="1">
